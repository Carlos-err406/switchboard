{
  "name": "switchboard-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --timestamp-format 'HH:mm:ss' --prefix '[{time} {name}\t]' -n dashboard,convex -c cyan,yellow 'pnpm --filter @switchboard/dashboard dev' 'pnpm --filter @switchboard/backend dev'",
    "dev:landing": "pnpm --filter @switchboard/landing dev",
    "dev:backend": "pnpm --filter @switchboard/backend dev",
    "build": "pnpm -r build",
    "lint": "eslint",
    "format": "prettier --write .",
    "check": "prettier --check ."
  },
  "devDependencies": {
    "@tanstack/eslint-config": "latest",
    "concurrently": "^9.2.1",
    "eslint": "^9.20.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "lightningcss"
    ]
  }
}
