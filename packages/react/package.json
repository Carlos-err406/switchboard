{
  "name": "@switchboard/react",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": ["dist"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outdir=dist --packages=external --minify && tsc -p tsconfig.build.json --emitDeclarationOnly"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.15"
  },
  "dependencies": {
    "@switchboard/common": "workspace:*",
    "@switchboard/js": "workspace:*",
    "convex": "^1.39.1"
  }
}
